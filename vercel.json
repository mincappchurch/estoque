{
  "version": 2,
  "buildCommand": "EXPO_USE_METRO_WORKSPACE_ROOT=1 npx expo export -p web --clear",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
